---
const { pkg } = Astro.props;
---

<a href={pkg.homepage} class="block p-2 rounded-2xl hover:bg-orange-200" target="_blank">
	<h3 class="text-lg font-semibold">
		{pkg.name}
		<span class="text-sm text-black-500 [font-variant-caps:all-small-caps]">v.{pkg.version}</span>
	</h3>
	<p class="text-black">{pkg.description}</p>
</a>
